.section-title{color:#00cc33;letter-spacing:3px;font-size:10px;margin-bottom:8px;margin-top:14px;border-bottom:1px solid #0f2a0f;padding-bottom:6px;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px;}
.stat-card{border:1px solid #0f2a0f;background:#050f05;padding:8px 10px;}
.stat-card.full{grid-column:1/-1;}
.stat-card.hi{border-color:#00aaff;}
.stat-label{color:#006618;font-size:9px;letter-spacing:2px;margin-bottom:4px;}
